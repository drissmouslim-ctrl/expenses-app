# Supabase — récupère ces valeurs dans Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# PIN d'accès à l'application (chiffres uniquement, ex: 1234)
APP_PIN=1234

# Secret utilisé pour signer le cookie de session (chaîne aléatoire longue)
SESSION_SECRET=change-moi-par-une-longue-chaine-aleatoire-secrete
